# ============================================================
# Get Up & Glo — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ============================================================

# --- Neon PostgreSQL ---
# Connection pooling URL (used by Prisma at runtime)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require&pgbouncer=true"

# Direct connection URL (used by Prisma for migrations)
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# --- Clerk ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# Clerk redirect paths
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/dashboard"

# --- Anthropic ---
ANTHROPIC_API_KEY="sk-ant-..."

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
